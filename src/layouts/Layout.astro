---
import { ClientRouter } from "astro:transitions";
import MainNavbar from "../components/MainNavbar.jsx";
import GeneracionToast from "../components/Horarios/GeneracionToast.jsx";
import "../styles/global.css";

const { title = "Dashboard | HoraVlep" } = Astro.props;
const currentPath = Astro.url.pathname;

// Fondo global para todas las páginas
const bodyBg = "#f8fafc";
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>{title}</title>
		<script is:inline>
			if (!localStorage.getItem("user")) {
				window.location.href = "/login";
			}
			// Global interceptor for API calls to bypass CORS sin backend
			if (!window.__fetchIntercepted) {
				window.__fetchIntercepted = true;
				const originalFetch = window.fetch;
				window.fetch = function (...args) {
					if (typeof args[0] === "string") {
						if (args[0].startsWith("http://127.0.0.1:8000/api")) {
							args[0] = args[0].replace(
								"http://127.0.0.1:8000/api",
								"/api",
							);
						} else if (args[0].startsWith("http://localhost:8000/api")) {
							args[0] = args[0].replace(
								"http://localhost:8000/api",
								"/api",
							);
						}
					}
					return originalFetch.apply(this, args);
				};
			}
		</script>
		<ClientRouter />
	</head>
	<body
		class="text-[var(--color-brand-black)] font-sans antialiased h-screen overflow-hidden transition-colors duration-500"
		style={`background-color: ${bodyBg};`}
	>
		<!-- Nuevo Topbar Interactivo Global -->
		<MainNavbar client:load currentPath={currentPath} transition:persist="main-navbar" />

		<!-- Contenedor principal a pantalla completa -->
		<div
			class="flex flex-col h-[calc(100vh-5rem)] overflow-y-auto overflow-x-hidden mt-20"
		>
			<main class="p-8 flex-1 w-full max-w-screen-2xl mx-auto">
				<slot />
			</main>
		</div>
		
		<!-- Toast global de generación de horarios -->
		<GeneracionToast client:load transition:persist />
	</body>
</html>
