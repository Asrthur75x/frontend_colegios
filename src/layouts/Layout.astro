---
import { ClientRouter } from "astro:transitions";
import Sidebar from "../components/Sidebar.jsx";
import SidebarHorarios from "../components/SidebarHorarios.jsx";
import GeneracionToast from "../components/Horarios/GeneracionToast.jsx";
import Topbar from "../components/Topbar.astro";
import "../styles/global.css";

const { title = "Dashboard | HorariX" } = Astro.props;
const currentPath = Astro.url.pathname;
const isHorarios = currentPath.startsWith("/horarios");

// Fondo global para todas las páginas
const bodyBg = '#FFFFFF';
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>{title}</title>
		<script is:inline>
			if (!localStorage.getItem("user")) {
				window.location.href = "/login";
			}
			// Global interceptor for API calls to bypass CORS without backend changes
			if (!window.__fetchIntercepted) {
				window.__fetchIntercepted = true;
				const originalFetch = window.fetch;
				window.fetch = function(...args) {
					if (typeof args[0] === 'string') {
						if (args[0].startsWith('http://127.0.0.1:8000/api')) {
							args[0] = args[0].replace('http://127.0.0.1:8000/api', '/api');
						} else if (args[0].startsWith('http://localhost:8000/api')) {
							args[0] = args[0].replace('http://localhost:8000/api', '/api');
						}
					}
					return originalFetch.apply(this, args);
				};
			}
		</script>
		<ClientRouter />

	</head>
	<body
		class="text-[var(--color-brand-black)] font-sans antialiased h-screen overflow-hidden pt-20 transition-colors duration-500"
		style={`background-color: ${bodyBg};`}
	>
		<Topbar />

		{isHorarios
			? <SidebarHorarios client:load currentPath={currentPath} transition:persist="sidebar-horarios" />
			: <Sidebar client:load currentPath={currentPath} transition:persist="sidebar-main" />
		}

		<!-- El margen izquierdo de 64 equivale al w-64 (16rem/256px) del Sidebar fixado -->
		<div
			class="ml-64 flex flex-col h-[calc(100vh-5rem)] overflow-y-auto overflow-x-hidden"
			style="background-color: #fff;"
		>
			<main class="p-8 flex-1">
				<slot />
			</main>
		</div>
		<!-- Toast global de generación de horarios -->
		<GeneracionToast client:load transition:persist />
	</body>
</html>
