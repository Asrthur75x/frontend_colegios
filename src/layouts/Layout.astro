---
import Sidebar from "../components/Sidebar.jsx";
import Topbar from "../components/Topbar.astro";
import "../styles/global.css";
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>Dashboard | HorariX</title>
	</head>
	<body
		class="bg-hx-blue text-[#757680] font-sans antialiased h-screen overflow-hidden pt-20"
	>
		<Topbar />
		<Sidebar client:load />

		<!-- El margen izquierdo de 64 equivale al w-64 (16rem/256px) del Sidebar fixado -->
		<div
			class="ml-64 bg-[#F8FAFC] flex flex-col h-[calc(100vh-5rem)] overflow-y-auto overflow-x-hidden"
		>
			<main class="p-8 flex-1">
				<slot />
			</main>
		</div>
	</body>
</html>
