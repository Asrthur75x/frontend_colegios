---
// Topbar.astro
---

<header
    class="h-16 w-full fixed top-0 left-0 bg-[#1A5AD7] rounded-b-[40px] shadow-md flex items-center justify-between px-8 z-50 text-white"
>
    <!-- Izquierda: Logo -->
    <div class="flex-1 flex justify-start">
        <h1
            class="text-3xl font-black tracking-tight text-white drop-shadow-sm"
        >
            HorariX
        </h1>
    </div>

    <!-- Centro: Navegación -->
    <div class="flex-1 flex justify-center h-full">
        <nav class="hidden md:flex gap-8 items-center h-full">
            <!-- Elemento Activo -->
            <a
                href="#"
                class="bg-white/20 text-white px-4 py-2 rounded-xl text-sm font-bold shadow-inner transition-all border border-white/10"
            >
                Dashboard
            </a>
            <!-- Elementos Inactivos -->
            <a
                href="#"
                class="text-white/70 hover:text-white text-sm font-semibold relative group py-2.5 transition-colors"
            >
                Horarios
                <span
                    class="absolute bottom-0 left-1/2 w-0 h-[2.5px] bg-white transition-all duration-300 ease-out group-hover:w-full group-hover:left-0 rounded-full"
                ></span>
            </a>
        </nav>
    </div>

    <!-- Derecha: Acciones -->
    <div class="flex-1 flex items-center justify-end gap-5">
        <button
            class="text-white/80 hover:text-white transition-colors relative"
        >
            <svg
                xmlns="http://www.w3.org/2000/svg"
                width="20"
                height="20"
                fill="none"
                stroke="currentColor"
                stroke-width="2.5"
                stroke-linecap="round"
                stroke-linejoin="round"
                ><path d="M6 8a6 6 0 0 1 12 0c0 7 3 9 3 9H3s3-2 3-9"
                ></path><path d="M10.3 21a1.94 1.94 0 0 0 3.4 0"></path></svg
            >
            <!-- Indicator punto rojo -->
            <span
                class="absolute -top-0.5 -right-0.5 w-2.5 h-2.5 bg-red-400 rounded-full border-[1.5px] border-[#1A5AD7]"
            ></span>
        </button>

        <button class="text-white/80 hover:text-white transition-colors">
            <svg
                xmlns="http://www.w3.org/2000/svg"
                width="20"
                height="20"
                fill="none"
                stroke="currentColor"
                stroke-width="2.5"
                stroke-linecap="round"
                stroke-linejoin="round"
                ><path
                    d="M12.22 2h-.44a2 2 0 0 0-2 2v.18a2 2 0 0 1-1 1.73l-.43.25a2 2 0 0 1-2 0l-.15-.08a2 2 0 0 0-2.73.73l-.22.38a2 2 0 0 0 .73 2.73l.15.1a2 2 0 0 1 1 1.72v.51a2 2 0 0 1-1 1.74l-.15.09a2 2 0 0 0-.73 2.73l.22.38a2 2 0 0 0 2.73.73l.15-.08a2 2 0 0 1 2 0l.43.25a2 2 0 0 1 1 1.73V20a2 2 0 0 0 2 2h.44a2 2 0 0 0 2-2v-.18a2 2 0 0 1 1-1.73l.43-.25a2 2 0 0 1 2 0l.15.08a2 2 0 0 0 2.73-.73l.22-.39a2 2 0 0 0-.73-2.73l-.15-.08a2 2 0 0 1-1-1.74v-.5a2 2 0 0 1 1-1.74l.15-.09a2 2 0 0 0 .73-2.73l-.22-.38a2 2 0 0 0-2.73-.73l-.15.08a2 2 0 0 1-2 0l-.43-.25a2 2 0 0 1-1-1.73V4a2 2 0 0 0-2-2z"
                ></path><circle cx="12" cy="12" r="3"></circle></svg
            >
        </button>

        <div class="h-6 w-px bg-white/30 mx-2"></div>

        <div
            class="w-9 h-9 rounded-full bg-white flex items-center justify-center text-[#1A5AD7] font-black text-sm shadow-md cursor-pointer hover:scale-105 transition-transform border-2 border-white/20"
        >
            U
        </div>
    </div>
</header>
