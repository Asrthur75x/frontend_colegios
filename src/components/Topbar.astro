---
// Topbar.astro
const pathname = Astro.url.pathname;
let pageTitle = "Dashboard";

if (
    pathname.includes("/areas") ||
    pathname.includes("/cursos") ||
    pathname.includes("/planes")
) {
    pageTitle = "Módulo Académico";
} else if (
    pathname.includes("/profesores") ||
    pathname.includes("/carga-academica") ||
    pathname.includes("/tutorias") ||
    pathname.includes("/asignacion-cursos")
) {
    pageTitle = "Módulo Docente";
} else if (pathname.includes("/horarios")) {
    pageTitle = "Centro de Horarios";
}

const isHorarios = pathname.includes("/horarios");
const isDashboard =
    !isHorarios &&
    (pathname === "/" || pathname === "" || pathname.includes("/dashboard"));
const isAjustes = pathname.startsWith("/ajustes");

const sidebarColor = pathname.startsWith("/ajustes")
    ? "var(--color-hx-yellow)"
    : pathname.startsWith("/horarios")
      ? "var(--color-hx-red)"
      : "rgba(121, 14, 236, 0.95)";
---

<header
    class="h-20 w-[calc(100%-16rem)] fixed top-0 left-64 rounded-tl-[32px] flex items-center justify-between px-10 z-40 text-[#111827]"
    style="background-color: #fff;"
>
    <!-- Esquina decorativa: muestra el color del sidebar en la esquina top-left -->
    <div
        style={`position:absolute;top:0;left:0;width:32px;height:32px;background-color:transparent;border-bottom-right-radius:32px;box-shadow:-16px -16px 0 16px ${sidebarColor};pointer-events:none;`}
    >
    </div>
    <!-- Izquierda: Hamburger & Título -->
    <div class="flex-1 flex items-center gap-5 justify-start">
        <button
            class="text-slate-600 hover:text-[#111827] transition-colors mt-1 cursor-pointer"
        >
            <svg
                xmlns="http://www.w3.org/2000/svg"
                width="26"
                height="26"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2.5"
                stroke-linecap="round"
                stroke-linejoin="round"
                ><line x1="3" y1="12" x2="21" y2="12"></line><line
                    x1="3"
                    y1="6"
                    x2="21"
                    y2="6"></line><line x1="3" y1="18" x2="13" y2="18"
                ></line></svg
            >
        </button>
        <h2
            class="text-2xl font-black tracking-tight text-[#111827]"
            id="topbar-title"
        >
            {pageTitle}
        </h2>
    </div>

    <!-- Centro: Navegación -->
    <div class="flex-1 flex justify-center h-full">
        <nav class="hidden md:flex gap-8 items-center h-full">
            <!-- Dashboard -->
            <a
                href="/dashboard"
                class={isDashboard
                    ? "bg-white text-[#111827] px-5 py-2.5 rounded-2xl text-sm font-extrabold shadow-sm transition-all border border-slate-200 hover:shadow-md"
                    : "relative px-4 py-2 text-sm font-bold text-slate-500 hover:text-[#111827] transition-colors rounded-xl"}
            >
                Dashboard
            </a>
            <!-- Horarios -->
            <a
                href="/horarios"
                id="nav-horarios"
                class={isHorarios
                    ? "bg-white text-[#111827] px-5 py-2.5 rounded-2xl text-sm font-extrabold shadow-sm transition-all border border-slate-200 hover:shadow-md"
                    : "relative inline-flex items-center justify-center px-4 py-2 text-sm font-bold text-slate-500 hover:text-[#111827] transition-colors rounded-xl overflow-hidden group"}
            >
                {
                    !isHorarios && (
                        <>
                            <span
                                id="horarios-spin-border"
                                class="absolute inset-0 w-full h-full hidden pointer-events-none"
                            >
                                <span class="absolute w-[200%] h-[200%] top-[-50%] left-[-50%] custom-spin-bg" />
                            </span>
                            <span
                                id="horarios-inner-bg"
                                class="absolute inset-[1.5px] bg-white rounded-[10px] hidden pointer-events-none"
                            />
                        </>
                    )
                }
                <span class="relative z-10">Horarios</span>
                {
                    !isHorarios && (
                        <span
                            id="horarios-underline"
                            class="absolute bottom-0 left-1/2 w-0 h-[3px] bg-hx-purple transition-all duration-300 ease-out group-hover:w-full group-hover:left-0 rounded-full"
                        />
                    )
                }
            </a>
        </nav>
    </div>

    <!-- Derecha: Acciones y Perfil -->
    <div class="flex-1 flex items-center justify-end gap-6">
        <div class="flex items-center gap-4">
            <!-- Configuración -->
            <a
                href="/ajustes"
                class={`relative w-11 h-11 bg-white rounded-full border flex items-center justify-center transition-all cursor-pointer hover:rotate-90 duration-300 ${
                    isAjustes
                        ? "border-hx-yellow text-hx-yellow shadow-md shadow-hx-yellow/20"
                        : "shadow-sm border-slate-100 text-slate-600 hover:text-[#111827] hover:shadow-md"
                }`}
            >
                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="20"
                    height="20"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2.5"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                >
                    <circle cx="12" cy="12" r="3"></circle>
                    <path
                        d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"
                    ></path>
                </svg>
            </a>
        </div>

        <div class="w-px h-8 bg-slate-200 mx-2"></div>

        <!-- Perfil -->
        <div
            class="flex items-center gap-3 cursor-pointer group hover:opacity-80 transition-opacity"
        >
            <div
                class="w-11 h-11 rounded-full bg-hx-purple text-white flex items-center justify-center font-black text-xl shadow-sm border-2 border-white"
            >
                <span id="user-initial">A</span>
            </div>
        </div>
    </div>
</header>

<script>
    // Script cliente para actualizar la inicial si hay datos en BD/Session
    document.addEventListener("astro:page-load", () => {
        // Ejemplo: Si el usuario tiene nombre guardado
        const storedName = sessionStorage.getItem("admin_name") || "Admin";
        const initialEl = document.getElementById("user-initial");
        if (initialEl) {
            initialEl.textContent = storedName.charAt(0).toUpperCase();
        }

        // Indicador dinámico de Horarios (Borde giratorio)
        const checkHorariosStatus = () => {
            const isReady = localStorage.getItem("configReady") === "true";
            console.log("Topbar: Verificando configReady ->", isReady);

            const spinBorder = document.getElementById("horarios-spin-border");
            const innerBg = document.getElementById("horarios-inner-bg");
            const underline = document.getElementById("horarios-underline");
            const star = document.getElementById("horarios-star");
            const nav = document.getElementById("nav-horarios");

            if (spinBorder && innerBg && nav) {
                if (isReady) {
                    spinBorder.classList.remove("hidden");
                    innerBg.classList.remove("hidden");
                    if (star) star.classList.remove("hidden");
                    if (underline) underline.classList.add("hidden");

                    nav.classList.add(
                        "text-[#1A5AD7]",
                        "shadow-sm",
                        "border",
                        "border-transparent",
                    );
                    nav.classList.remove(
                        "text-slate-500",
                        "hover:text-[#111827]",
                    );
                } else {
                    spinBorder.classList.add("hidden");
                    innerBg.classList.add("hidden");
                    if (star) star.classList.add("hidden");
                    if (underline) underline.classList.remove("hidden");

                    nav.classList.remove(
                        "text-[#1A5AD7]",
                        "shadow-sm",
                        "border",
                        "border-transparent",
                    );
                    nav.classList.add("text-slate-500", "hover:text-[#111827]");
                }
            }
        };

        checkHorariosStatus();
        window.addEventListener("horarix_config_ready", checkHorariosStatus);
    });
</script>

<style>
    @keyframes customSpin {
        0% {
            transform: rotate(0deg);
        }
        100% {
            transform: rotate(360deg);
        }
    }
    .custom-spin-bg {
        background: conic-gradient(
            from 0deg,
            transparent 0 300deg,
            #1a5ad7 360deg
        );
        animation: customSpin 2s linear infinite;
    }
</style>
