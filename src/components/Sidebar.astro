---
// Sidebar.astro
const pathname = Astro.url.pathname;
const currentPath = pathname.replace(/\/$/, ""); // quitar trailing slash si hay
---

<aside
    class="w-64 bg-white border-r border-slate-100 flex flex-col justify-between fixed h-[calc(100vh-4rem)] top-16 left-0 z-40 overflow-y-auto"
>
    <div class="p-6">
        <!-- Título discreto -->
        <div class="mb-6 pl-2">
            <p
                class="text-[12px] font-bold text-[#64748B] uppercase tracking-[0.2em] flex items-center gap-2"
            >
                <span class="w-1.5 h-1.5 rounded-full bg-[#1A5AD7]"></span>
                Gestión Académica
            </p>
        </div>

        <nav class="space-y-2">
            <!-- Inicio -->
            <a
                href="/"
                class={`flex items-center gap-3 px-4 py-3 rounded-xl transition-all ${currentPath === "" ? "font-bold text-[#1A5AD7] bg-[#1A5AD7]/10 shadow-sm" : "text-[#64748B] hover:text-[#111827] hover:bg-slate-50 font-semibold"}`}
            >
                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="20"
                    height="20"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2.5"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    ><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"
                    ></path><polyline points="9 22 9 12 15 12 15 22"
                    ></polyline></svg
                >
                Inicio
            </a>

            <!-- Áreas Académicas -->
            <a
                href="/areas"
                class={`flex items-center gap-3 px-4 py-3 rounded-xl transition-all ${currentPath.startsWith("/areas") ? "font-bold text-[#1A5AD7] bg-[#1A5AD7]/10 shadow-sm" : "text-[#64748B] hover:text-[#111827] hover:bg-slate-50 font-semibold"}`}
            >
                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="20"
                    height="20"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    ><rect x="3" y="3" width="7" height="7"></rect><rect
                        x="14"
                        y="3"
                        width="7"
                        height="7"></rect><rect
                        x="14"
                        y="14"
                        width="7"
                        height="7"></rect><rect
                        x="3"
                        y="14"
                        width="7"
                        height="7"></rect></svg
                >
                Áreas Académicas
            </a>

            <!-- Cursos -->
            <a
                href="/cursos"
                class={`flex items-center gap-3 px-4 py-3 rounded-xl transition-all ${currentPath.startsWith("/cursos") ? "font-bold text-[#1A5AD7] bg-[#1A5AD7]/10 shadow-sm" : "text-[#64748B] hover:text-[#111827] hover:bg-slate-50 font-semibold"}`}
            >
                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="20"
                    height="20"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    ><path
                        d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H20v20H6.5a2.5 2.5 0 0 1 0-5H20"
                    ></path></svg
                >
                Cursos
            </a>

            <!-- Profesores -->
            <a
                href="/profesores"
                class={`flex items-center gap-3 px-4 py-3 rounded-xl transition-all ${currentPath.startsWith("/profesores") ? "font-bold text-[#1A5AD7] bg-[#1A5AD7]/10 shadow-sm" : "text-[#64748B] hover:text-[#111827] hover:bg-slate-50 font-semibold"}`}
            >
                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="20"
                    height="20"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    ><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"
                    ></path><circle cx="9" cy="7" r="4"></circle><path
                        d="M22 21v-2a4 4 0 0 0-3-3.87"></path><path
                        d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg
                >
                Profesores
            </a>

            <!-- Aulas -->
            <a
                href="/aulas"
                class={`flex items-center gap-3 px-4 py-3 rounded-xl transition-all ${currentPath.startsWith("/aulas") ? "font-bold text-[#1A5AD7] bg-[#1A5AD7]/10 shadow-sm" : "text-[#64748B] hover:text-[#111827] hover:bg-slate-50 font-semibold"}`}
            >
                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="20"
                    height="20"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    ><path d="M18 20V6a2 2 0 0 0-2-2H8a2 2 0 0 0-2 2v14"
                    ></path><path d="M2 20h20"></path><path d="M14 12v.01"
                    ></path></svg
                >
                Aulas
            </a>

            <!-- Grados -->
            <a
                href="/grados"
                class={`flex items-center gap-3 px-4 py-3 rounded-xl transition-all ${currentPath.startsWith("/grados") ? "font-bold text-[#1A5AD7] bg-[#1A5AD7]/10 shadow-sm" : "text-[#64748B] hover:text-[#111827] hover:bg-slate-50 font-semibold"}`}
            >
                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="20"
                    height="20"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    ><path
                        d="M22 10v6M2 10l10-5 10 5-10 5zM6 12v5c3 3 9 3 12 0v-5"
                    ></path></svg
                >
                Grados
            </a>
        </nav>
    </div>

    <div class="p-6 bg-white">
        <a
            href="#"
            class="flex items-center gap-3 text-red-600 font-bold px-4 py-3 hover:bg-red-50 hover:shadow-sm rounded-xl transition-all outline-none"
        >
            <svg
                xmlns="http://www.w3.org/2000/svg"
                width="18"
                height="18"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                ><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"
                ></path><polyline points="16 17 21 12 16 7"></polyline><line
                    x1="21"
                    y1="12"
                    x2="9"
                    y2="12"></line></svg
            >
            Cerrar Sesión
        </a>
    </div>
</aside>
