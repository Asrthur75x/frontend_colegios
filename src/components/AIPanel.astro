---
// AIPanel.astro
---

<section
    id="ai-panel"
    class="hidden translate-y-4 transform relative overflow-hidden rounded-2xl border border-[#6366F1]/30 bg-gradient-to-br from-[#6366F1]/5 to-white p-8 opacity-0 shadow-sm transition-all duration-500"
>
    <div class="absolute left-0 top-0 h-full w-2 bg-[#6366F1]"></div>
    <div class="flex items-start gap-4">
        <div
            class="flex h-12 w-12 flex-shrink-0 items-center justify-center rounded-full bg-[#6366F1] font-bold text-white shadow-md shadow-[#6366F1]/30"
        >
            <svg
                xmlns="http://www.w3.org/2000/svg"
                width="24"
                height="24"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                ><path
                    d="M9.937 15.5A2 2 0 0 0 8.5 14.063l-6.135-1.582a.5.5 0 0 1 0-.962L8.5 9.936A2 2 0 0 0 9.937 8.5l1.582-6.135a.5.5 0 0 1 .963 0L14.063 8.5A2 2 0 0 0 15.5 9.937l6.135 1.581a.5.5 0 0 1 0 .964L15.5 14.063a2 2 0 0 0-1.437 1.437l-1.582 6.135a.5.5 0 0 1-.963 0z"
                ></path><path d="M20 3v4"></path><path d="M22 5h-4"></path><path
                    d="M4 17v2"></path><path d="M5 18H3"></path></svg
            >
        </div>
        <div class="flex-1">
            <h3
                class="mb-2 flex items-center gap-3 text-xl font-bold text-[#6366F1]"
            >
                Agente IA Evaluador
                <span
                    id="ai-status-badge"
                    class="animate-pulse rounded bg-[#6366F1]/20 px-2 py-0.5 text-[10px] uppercase tracking-wider text-[#6366F1]"
                    >Analizando</span
                >
            </h3>
            <p
                id="ai-summary"
                class="text-lg leading-relaxed text-[#757680] transition-all duration-300"
            >
            </p>
        </div>
    </div>
</section>
